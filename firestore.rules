rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: progress
    // Document ID: progressCode, e.g. G1-1234
    // Fields:
    //   - progressCode: string, immutable, same as document ID
    //   - name: string, 1-80 chars
    //   - groupId: int, 1-14, immutable
    //   - linkedUids: list, 1-8 Firebase Auth anonymous UIDs/prototype recovery IDs
    //   - completedSteps, badges, downloads, unlockedDownloads: bounded lists
    //   - checkpointAnswers: map, bounded by key count
    //   - checkpointScore, totalCheckpoints, setupStepIndex, learnStepIndex,
    //     rebuildStepIndex, understandStepIndex: bounded ints
    //   - setupCompletedSteps, learnCompletedSteps, rebuildCompletedSteps,
    //     understandCompletedSteps: bounded lists
    //   - createdAt, updatedAt: ISO date strings from the client
    //
    // Collection: groupBoards/{groupId}/members
    // Document ID: Firebase Auth UID
    // Fields:
    //   - id: string, immutable, same as document ID
    //   - name: string, 1-80 chars
    //   - groupId: int, 1-14
    //   - completionPercent: int, 0-100
    //   - completedSteps, totalSteps, badgeCount, nudgeCount: non-negative ints
    //   - readyForGroupMission: bool
    //   - lastStepTitle: string, 1-80 chars
    //   - updatedAt: ISO date string from the client
    //
    // Collection: groupBoards/{groupId}/members/{uid}/notifications
    // Document ID: generated ID
    // Fields:
    //   - id: string, same as document ID
    //   - groupId: int, 1-14
    //   - recipientId: string, same as parent member ID
    //   - senderId: string, same as request.auth.uid
    //   - senderName: string, 1-80 chars
    //   - message: string, 1-180 chars
    //   - createdAt: ISO date string from the client
    //   - readAt: null on create, string after recipient marks read
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function signedIn() {
      return request.auth != null;
    }

    function validString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function validIsoDate(value) {
      return value is string
        && value.size() >= 20
        && value.size() <= 40
        && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*');
    }

    function validGroupPath(groupId) {
      return groupId.matches('^([1-9]|1[0-4])$');
    }

    function validGroupNumber(value) {
      return value is int && value >= 1 && value <= 14;
    }

    function groupPathMatchesNumber(groupId, value) {
      return (groupId == '1' && value == 1)
        || (groupId == '2' && value == 2)
        || (groupId == '3' && value == 3)
        || (groupId == '4' && value == 4)
        || (groupId == '5' && value == 5)
        || (groupId == '6' && value == 6)
        || (groupId == '7' && value == 7)
        || (groupId == '8' && value == 8)
        || (groupId == '9' && value == 9)
        || (groupId == '10' && value == 10)
        || (groupId == '11' && value == 11)
        || (groupId == '12' && value == 12)
        || (groupId == '13' && value == 13)
        || (groupId == '14' && value == 14);
    }

    function validProgressCode(code) {
      return code is string && code.matches('^G([1-9]|1[0-4])-[0-9]{4}$');
    }

    function progressCodeMatchesGroupNumber(code, value) {
      return (value == 1 && code.matches('^G1-[0-9]{4}$'))
        || (value == 2 && code.matches('^G2-[0-9]{4}$'))
        || (value == 3 && code.matches('^G3-[0-9]{4}$'))
        || (value == 4 && code.matches('^G4-[0-9]{4}$'))
        || (value == 5 && code.matches('^G5-[0-9]{4}$'))
        || (value == 6 && code.matches('^G6-[0-9]{4}$'))
        || (value == 7 && code.matches('^G7-[0-9]{4}$'))
        || (value == 8 && code.matches('^G8-[0-9]{4}$'))
        || (value == 9 && code.matches('^G9-[0-9]{4}$'))
        || (value == 10 && code.matches('^G10-[0-9]{4}$'))
        || (value == 11 && code.matches('^G11-[0-9]{4}$'))
        || (value == 12 && code.matches('^G12-[0-9]{4}$'))
        || (value == 13 && code.matches('^G13-[0-9]{4}$'))
        || (value == 14 && code.matches('^G14-[0-9]{4}$'));
    }

    function validBoundedList(value, maxSize) {
      return value is list && value.size() <= maxSize;
    }

    function signedInMemberOfGroup(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groupBoards/$(groupId)/members/$(request.auth.uid));
    }

    function validProgressRecord(code) {
      return request.resource.data.keys().hasOnly([
          'progressCode',
          'name',
          'groupId',
          'linkedUids',
          'completedSteps',
          'checkpointAnswers',
          'checkpointScore',
          'totalCheckpoints',
          'badges',
          'downloads',
          'unlockedDownloads',
          'setupStepIndex',
          'setupCompletedSteps',
          'learnStepIndex',
          'learnCompletedSteps',
          'rebuildStepIndex',
          'rebuildCompletedSteps',
          'understandStepIndex',
          'understandCompletedSteps',
          'createdAt',
          'updatedAt',
        ])
        && request.resource.data.progressCode == code
        && validProgressCode(request.resource.data.progressCode)
        && validString(request.resource.data.name, 1, 80)
        && validGroupNumber(request.resource.data.groupId)
        && progressCodeMatchesGroupNumber(request.resource.data.progressCode, request.resource.data.groupId)
        && validBoundedList(request.resource.data.linkedUids, 8)
        && request.resource.data.linkedUids.size() >= 1
        && request.auth.uid in request.resource.data.linkedUids
        && validBoundedList(request.resource.data.completedSteps, 7)
        && request.resource.data.checkpointAnswers is map
        && request.resource.data.checkpointAnswers.keys().size() <= 60
        && request.resource.data.checkpointScore is int
        && request.resource.data.checkpointScore >= 0
        && request.resource.data.totalCheckpoints is int
        && request.resource.data.totalCheckpoints >= 1
        && request.resource.data.totalCheckpoints <= 20
        && request.resource.data.checkpointScore <= request.resource.data.totalCheckpoints
        && validBoundedList(request.resource.data.badges, 10)
        && validBoundedList(request.resource.data.downloads, 20)
        && validBoundedList(request.resource.data.unlockedDownloads, 20)
        && request.resource.data.setupStepIndex is int
        && request.resource.data.setupStepIndex >= 0
        && request.resource.data.setupStepIndex <= 10
        && validBoundedList(request.resource.data.setupCompletedSteps, 10)
        && request.resource.data.learnStepIndex is int
        && request.resource.data.learnStepIndex >= 0
        && request.resource.data.learnStepIndex <= 20
        && validBoundedList(request.resource.data.learnCompletedSteps, 20)
        && request.resource.data.rebuildStepIndex is int
        && request.resource.data.rebuildStepIndex >= 0
        && request.resource.data.rebuildStepIndex <= 20
        && validBoundedList(request.resource.data.rebuildCompletedSteps, 20)
        && request.resource.data.understandStepIndex is int
        && request.resource.data.understandStepIndex >= 0
        && request.resource.data.understandStepIndex <= 20
        && validBoundedList(request.resource.data.understandCompletedSteps, 20)
        && validIsoDate(request.resource.data.createdAt)
        && validIsoDate(request.resource.data.updatedAt);
    }

    function canCreateProgress(code) {
      return signedIn() && validProgressRecord(code);
    }

    function canUpdateOwnProgress(code) {
      return signedIn()
        && request.auth.uid in resource.data.linkedUids
        && validProgressRecord(code)
        && request.resource.data.progressCode == resource.data.progressCode
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function canRecoverByCodeOnly(code) {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedUids', 'updatedAt'])
        && request.resource.data.linkedUids is list
        && request.resource.data.linkedUids.hasAll(resource.data.linkedUids)
        && request.resource.data.linkedUids.size() <= 8
        && request.auth.uid in request.resource.data.linkedUids
        && validIsoDate(request.resource.data.updatedAt)
        && validProgressRecord(code);
    }

    function validGroupMember(groupId, memberId) {
      return signedIn()
        && validGroupPath(groupId)
        && request.auth.uid == memberId
        && request.resource.data.keys().hasOnly([
          'id',
          'name',
          'groupId',
          'completionPercent',
          'completedSteps',
          'readyForGroupMission',
          'totalSteps',
          'lastStepTitle',
          'badgeCount',
          'nudgeCount',
          'updatedAt',
        ])
        && request.resource.data.id == memberId
        && validString(request.resource.data.name, 1, 80)
        && validGroupNumber(request.resource.data.groupId)
        && groupPathMatchesNumber(groupId, request.resource.data.groupId)
        && request.resource.data.completionPercent is int
        && request.resource.data.completionPercent >= 0
        && request.resource.data.completionPercent <= 100
        && request.resource.data.completedSteps is int
        && request.resource.data.completedSteps >= 0
        && request.resource.data.completedSteps <= 7
        && request.resource.data.readyForGroupMission is bool
        && request.resource.data.totalSteps is int
        && request.resource.data.totalSteps >= 1
        && request.resource.data.totalSteps <= 10
        && validString(request.resource.data.lastStepTitle, 1, 80)
        && request.resource.data.badgeCount is int
        && request.resource.data.badgeCount >= 0
        && request.resource.data.badgeCount <= 10
        && request.resource.data.nudgeCount is int
        && request.resource.data.nudgeCount >= 0
        && request.resource.data.nudgeCount <= 999
        && validIsoDate(request.resource.data.updatedAt);
    }

    function canNudgeOnly(groupId, memberId) {
      return signedIn()
        && validGroupPath(groupId)
        && signedInMemberOfGroup(groupId)
        && request.auth.uid != memberId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nudgeCount', 'updatedAt'])
        && request.resource.data.nudgeCount is int
        && resource.data.nudgeCount is int
        && request.resource.data.nudgeCount == resource.data.nudgeCount + 1
        && request.resource.data.nudgeCount <= 999
        && validIsoDate(request.resource.data.updatedAt);
    }

    function validNotificationCreate(groupId, memberId, notificationId) {
      return signedIn()
        && validGroupPath(groupId)
        && signedInMemberOfGroup(groupId)
        && request.auth.uid != memberId
        && request.resource.data.keys().hasOnly([
          'id',
          'groupId',
          'recipientId',
          'senderId',
          'senderName',
          'message',
          'createdAt',
          'readAt',
        ])
        && request.resource.data.id == notificationId
        && validString(request.resource.data.id, 1, 120)
        && validGroupNumber(request.resource.data.groupId)
        && groupPathMatchesNumber(groupId, request.resource.data.groupId)
        && request.resource.data.recipientId == memberId
        && request.resource.data.senderId == request.auth.uid
        && validString(request.resource.data.senderName, 1, 80)
        && validString(request.resource.data.message, 1, 180)
        && validIsoDate(request.resource.data.createdAt)
        && request.resource.data.readAt == null;
    }

    function canMarkNotificationRead(memberId) {
      return signedIn()
        && request.auth.uid == memberId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt'])
        && resource.data.readAt == null
        && validIsoDate(request.resource.data.readAt);
    }

    match /progress/{code} {
      allow list: if false;
      allow get: if signedIn();
      allow create: if canCreateProgress(code);
      allow update: if canUpdateOwnProgress(code) || canRecoverByCodeOnly(code);
      allow delete: if false;
    }

    match /groupBoards/{groupId}/members/{memberId} {
      allow get, list: if signedIn() && validGroupPath(groupId);
      allow create: if validGroupMember(groupId, memberId);
      allow update: if validGroupMember(groupId, memberId) || canNudgeOnly(groupId, memberId);
      allow delete: if false;

      match /notifications/{notificationId} {
        allow get, list: if signedIn() && request.auth.uid == memberId && validGroupPath(groupId);
        allow create: if validNotificationCreate(groupId, memberId, notificationId);
        allow update: if canMarkNotificationRead(memberId);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
